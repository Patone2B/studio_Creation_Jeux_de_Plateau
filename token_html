<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Éditeur Pro de Pions/Jetons/Dés</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="tokens.css">
</head>
<body>
    <div class="container">
        <header>
            <h1><i class="fas fa-paint-brush"></i> Éditeur Pro de Pions/Jetons/Dés</h1>
        </header>

        <!-- Barre d'outils -->
        <div class="toolbar">
            <div class="tool-group">
                <label><i class="fas fa-shapes"></i> Formes :</label>
                <select id="shapeSelect">
                    <option value="pencil">Crayon</option>
                    <option value="circle">Cercle</option>
                    <option value="square">Carré</option>
                    <option value="line">Ligne</option>
                    <option value="eraser">Gomme</option>
                </select>
            </div>

            <div class="tool-group">
                <label><i class="fas fa-fill-drip"></i> Couleur :</label>
                <input type="color" id="colorPicker" value="#000000">
            </div>

            <div class="tool-group">
                <label><i class="fas fa-text-width"></i> Épaisseur :</label>
                <input type="range" id="lineWidth" min="1" max="20" value="3">
            </div>

            <div class="tool-group">
                <label><i class="fas fa-font"></i> Texte :</label>
                <input type="text" id="textInput" placeholder="Texte ou numéro">
                <button id="addText"><i class="fas fa-plus"></i> Ajouter</button>
            </div>

            <div class="tool-group">
                <label><i class="fas fa-image"></i> Image :</label>
                <input type="file" id="imageUpload" accept="image/*">
            </div>

            <div class="tool-group">
                <button id="clearCanvas"><i class="fas fa-trash"></i> Effacer</button>
                <button id="saveLocal"><i class="fas fa-save"></i> Sauvegarder</button>
                <button id="loadLocal"><i class="fas fa-folder-open"></i> Charger</button>
                <button id="importJSON"><i class="fas fa-file-import"></i> Importer JSON</button>
                <button id="exportJSON"><i class="fas fa-file-export"></i> Exporter JSON</button>
                <button id="exportPNG"><i class="fas fa-file-image"></i> Exporter PNG</button>
            </div>
        </div>

        <!-- Zone de dessin -->
        <div class="canvas-container">
            <canvas id="tokenCanvas" width="800" height="600"></canvas>
        </div>
    </div>

    <script src="tokens.js"></script>
</body>
</html>
